# 从仓库根目录 source；目标服务器只需覆盖 LOCAL_DATA_ROOT。
export REWRITE_ROOT="$(pwd -P)"
export LOCAL_DATA_ROOT="${LOCAL_DATA_ROOT:-${REWRITE_ROOT}/.local-data}"

export REWRITE_ARTIFACT_ROOT="${REWRITE_ARTIFACT_ROOT:-${LOCAL_DATA_ROOT}/artifacts}"
export REWRITE_REGISTRY_PATH="${REWRITE_REGISTRY_PATH:-${REWRITE_ROOT}/artifacts/registry.jsonl}"
export QWEN_MODEL_DIR="${QWEN_MODEL_DIR:-${LOCAL_DATA_ROOT}/models/Qwen2.5-7B-Instruct}"

export TMPDIR="${TMPDIR:-${LOCAL_DATA_ROOT}/tmp}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-${LOCAL_DATA_ROOT}/cache}"
export PIP_CACHE_DIR="${PIP_CACHE_DIR:-${XDG_CACHE_HOME}/pip}"
export HF_HOME="${HF_HOME:-${XDG_CACHE_HOME}/huggingface}"
export TORCH_HOME="${TORCH_HOME:-${XDG_CACHE_HOME}/torch}"
export TRITON_CACHE_DIR="${TRITON_CACHE_DIR:-${XDG_CACHE_HOME}/triton}"
export PYTHONPATH="${REWRITE_ROOT}/src${PYTHONPATH:+:${PYTHONPATH}}"

# 保证 CUDA ordinal 与 nvidia-smi 的 PCI bus index 一致。
export CUDA_DEVICE_ORDER="${CUDA_DEVICE_ORDER:-PCI_BUS_ID}"
